<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Security Group: Nhan vien tu phuc vu -->
    <record id="group_nhan_vien" model="res.groups">
        <field name="name">Nhan vien (Self-Service)</field>
        <field name="category_id" ref="base.module_category_human_resources"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">Nhan vien co the tu check-in/check-out va xem phieu luong cua minh.</field>
    </record>

    <!-- Security Group: HR Manager -->
    <record id="group_hr_quan_ly" model="res.groups">
        <field name="name">HR Quan ly</field>
        <field name="category_id" ref="base.module_category_human_resources"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        <field name="comment">Quan ly nhan su toan quyen.</field>
    </record>

    <!-- Record Rule: Nhan vien chi xem cham cong cua minh -->
    <record id="rule_cham_cong_nhan_vien" model="ir.rule">
        <field name="name">Cham cong: Nhan vien chi xem cua minh</field>
        <field name="model_id" ref="model_hr_cham_cong"/>
        <field name="domain_force">[('nhan_vien_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_nhan_vien'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Record Rule: HR Manager xem tat ca -->
    <record id="rule_cham_cong_hr_manager" model="ir.rule">
        <field name="name">Cham cong: HR Manager xem tat ca</field>
        <field name="model_id" ref="model_hr_cham_cong"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_hr_quan_ly'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

