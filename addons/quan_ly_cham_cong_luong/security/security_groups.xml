        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Record Rule: HR Manager toan quyen voi phieu luong -->
    <record id="rule_phieu_luong_hr_manager" model="ir.rule">
        <field name="name">Phieu luong: HR Manager xem tat ca</field>
